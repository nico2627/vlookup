# Linear Regression for Salary Prediction based on Years of Experience

import pandas as pd
from sklearn.linear_model import LinearRegression
import matplotlib.pyplot as plt

# Dataset
data = {
"YearsExperience":[2,10,4,20,8,12,22],
"Salary":[30000,95000,45000,170000,84000,120000,200000]
}

df = pd.DataFrame(data)

# Features and Target
X = df[["YearsExperience"]]
y = df["Salary"]

# Train Linear Regression Model
model = LinearRegression()
model.fit(X,y)

# Predict salary for example (15 years experience)
predicted_salary = model.predict([[15]])

print("Predicted Salary for 15 years experience:", predicted_salary[0])

# Plot regression line
plt.scatter(X,y)
plt.plot(X,model.predict(X))
plt.xlabel("Years of Experience")
plt.ylabel("Salary")
plt.title("Linear Regression: Experience vs Salary")
plt.show()
